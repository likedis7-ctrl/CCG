rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'likedis7@cnsa.hs.kr';
    }

    function isCNSA() {
      return request.auth != null && request.auth.token.email.matches('.*@cnsa\\.hs\\.kr');
    }

    function isTeacher() {
      return isCNSA() && (
        isAdmin() ||
        get(/databases/$(database)/documents/settings/teachers)
          .data.emails.hasAny([request.auth.token.email])
      );
    }

    function isVeritasEditor() {
      return isCNSA() && (
        isAdmin() ||
        get(/databases/$(database)/documents/settings/veritasEditors)
          .data.emails.hasAny([request.auth.token.email])
      );
    }

    // 선생님 상담 슬롯
    match /teacherSlots/{dateKey} {
      allow read: if isCNSA();
      allow write: if isTeacher() || isAdmin();
    }

    // 예약
    match /bookings/{bookingId} {
      allow read: if isCNSA() && (
        resource.data.uid == request.auth.uid ||
        resource.data.teacherEmail == request.auth.token.email ||
        isAdmin()
      );
      allow create: if isCNSA();
      allow update: if isAdmin() ||
        (isTeacher() && resource.data.teacherEmail == request.auth.token.email);
      allow delete: if isAdmin() || resource.data.uid == request.auth.uid;
    }

    // 진로체험 이수시간 (doc ID: ${year}_${email})
    match /careerHours/{docId} {
      allow read: if isCNSA() && (
        resource.data.email == request.auth.token.email.lower() || isAdmin()
      );
      allow write: if isAdmin();
    }

    // 진로체험 활동내역 (doc ID: ${year}_${email})
    match /careerActivities/{docId} {
      allow read: if isCNSA() && (
        resource.data.email == request.auth.token.email.lower() || isAdmin()
      );
      allow write: if isAdmin();
    }

    // 동아리 목록 (doc ID: ${year}_${clubName})
    match /clubs/{clubId} {
      allow read: if isCNSA();
      allow write: if isAdmin();
    }

    // 동아리 PDF 보고서 (doc ID: ${year}_${clubName})
    match /clubReports/{reportId} {
      allow read: if isCNSA();
      allow write: if isTeacher() || isAdmin() ||
        (isCNSA() &&
          get(/databases/$(database)/documents/clubs/$(reportId))
            .data.leaderEmail == request.auth.token.email);
    }

    // 동아리 아티클
    function isClubLeader(year, clubId) {
      return isCNSA() &&
        get(/databases/$(database)/documents/clubs/$(string(year) + '_' + clubId))
          .data.leaderEmail == request.auth.token.email;
    }

    match /clubArticles/{articleId} {
      allow read: if isCNSA();
      allow create: if isTeacher() || isAdmin() ||
        isClubLeader(request.resource.data.year, request.resource.data.clubId);
      allow update, delete: if isAdmin() ||
        resource.data.authorEmail == request.auth.token.email ||
        isClubLeader(resource.data.year, resource.data.clubId);
    }

    // 동아리 아티클 좋아요
    match /clubArticleLikes/{articleId} {
      allow read: if isCNSA();
      // emails 배열에 자기 이메일만 추가/삭제할 수 있도록 제한
      allow create: if isCNSA() &&
        request.resource.data.keys().hasOnly(['emails']) &&
        request.resource.data.emails.hasOnly([request.auth.token.email]);
      allow update: if isCNSA() &&
        request.resource.data.keys().hasOnly(['emails']) &&
        (
          // 추가: 기존 목록 + 자기 이메일
          request.resource.data.emails.toSet() == resource.data.emails.toSet().union([request.auth.token.email].toSet()) ||
          // 삭제: 기존 목록 - 자기 이메일
          request.resource.data.emails.toSet() == resource.data.emails.toSet().difference([request.auth.token.email].toSet())
        );
    }

    // VERITAS CNSA 소식지
    match /veritasIssues/{issueId} {
      allow read: if isCNSA();
      allow write: if isVeritasEditor();
    }

    // 전역 설정 (clubWriting, veritasEditors 등)
    match /settings/{settingId} {
      allow read: if isCNSA();
      allow write: if isAdmin();
    }
  }
}
