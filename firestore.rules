rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'likedis7@cnsa.hs.kr';
    }

    function isCNSA() {
      return request.auth != null && request.auth.token.email.matches('.*@cnsa\\.hs\\.kr');
    }

    function isTeacher() {
      return request.auth != null && request.auth.token.email in [
        'kim@cnsa.hs.kr', 'lee@cnsa.hs.kr', 'park@cnsa.hs.kr',
        'choi@cnsa.hs.kr', 'jung@cnsa.hs.kr', 'han@cnsa.hs.kr', 'oh@cnsa.hs.kr'
      ];
    }

    function isClubLeader(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId)).data.leaderEmail == request.auth.token.email;
    }

    // 선생님 상담 슬롯
    match /teacherSlots/{dateKey} {
      allow read: if isCNSA();
      allow write: if isTeacher() || isAdmin();
    }

    // 예약
    match /bookings/{bookingId} {
      allow read: if isCNSA() && (
        resource.data.uid == request.auth.uid ||
        resource.data.teacherEmail == request.auth.token.email ||
        isAdmin()
      );
      allow create: if isCNSA();
      allow update: if isAdmin() || (isTeacher() && resource.data.teacherEmail == request.auth.token.email);
      allow delete: if isAdmin();
    }

    // 진로체험 이수시간
    match /careerHours/{email} {
      allow read: if isCNSA() && (
        request.auth.token.email.lower() == email || isAdmin()
      );
      allow write: if isAdmin();
    }

    // 동아리 목록
    match /clubs/{clubId} {
      allow read: if isCNSA();
      allow write: if isAdmin();
    }

    // 동아리 PDF 보고서
    match /clubReports/{clubId} {
      allow read: if isCNSA();
      allow write: if isTeacher() || isAdmin() || isClubLeader(clubId);
    }

    // 동아리 아티클
    match /clubArticles/{articleId} {
      allow read: if isCNSA();
      allow create: if isCNSA() && (
        isTeacher() || isAdmin() ||
        get(/databases/$(database)/documents/clubs/$(request.resource.data.clubId)).data.leaderEmail == request.auth.token.email
      );
      allow update, delete: if isAdmin() || resource.data.authorEmail == request.auth.token.email;
    }
  }
}
